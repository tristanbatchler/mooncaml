{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug server",
            "type": "ocaml.earlybird",
            "request": "launch",
            "program": "${workspaceFolder}/_build/default/bin/server_app.bc",
            "console": "integratedTerminal",
            "stopOnEntry": false,
            "yieldSteps": 1024,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug client",
            "type": "ocaml.earlybird",
            "request": "launch",
            "program": "${workspaceFolder}/_build/default/bin/client_app.bc",
            "console": "integratedTerminal",
            "stopOnEntry": false,
            "yieldSteps": 1024,
            "cwd": "${workspaceFolder}"
        }
    ]
}